# ════════════════════════════════════════════════════════════════
# EDITH AR — Copy to backend/.env and fill in your keys
# Only OPENROUTER_API_KEY is required. Everything else has fallbacks.
# ════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ── VOICE: STT (pick one) ─────────────────────────────────────────
# Option A: Groq Whisper — FREE 7200s/day, fastest, no credit card
# console.groq.com → API Keys → Create
GROQ_API_KEY=YOUR_GROQ_KEY

# Option B: Deepgram — 200hr free, streaming support
# deepgram.com → Console → API Keys
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY

# ── VOICE: TTS (pick one) ─────────────────────────────────────────
# Option A: ElevenLabs — BEST voice quality, JARVIS-like
# elevenlabs.io → Profile → API Key
# Free: 10,000 chars/month
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
# Voice IDs (George = deep JARVIS voice, default):
# JBFqnCBsd6RMkjVDRZzb = George  (deep, authoritative — recommended)
# TxGEqnHWrfWFTfGW9XjX = Josh    (young, energetic)
# pNInz6obpgDQGcFmaJgB = Adam    (neutral, clear)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Option B: Cartesia Sonic — fast streaming TTS
CARTESIA_API_KEY=YOUR_CARTESIA_KEY
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# (fallback if neither: gTTS — free, no key, robotic voice)

# ── GOOGLE (Gmail + YouTube + Calendar) ──────────────────────────
# console.cloud.google.com → OAuth 2.0 → Desktop app
GOOGLE_CLIENT_ID=YOUR_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_SECRET
YOUTUBE_API_KEY=YOUR_KEY

# ── WEB SEARCH (DuckDuckGo works with no keys) ────────────────────
GOOGLE_SEARCH_API_KEY=YOUR_KEY
GOOGLE_CSE_ID=YOUR_CSE_ID
SERPAPI_KEY=YOUR_KEY

# ── WHATSAPP ──────────────────────────────────────────────────────
WHATSAPP_TOKEN=YOUR_TOKEN
WHATSAPP_PHONE_ID=YOUR_PHONE_ID
WHATSAPP_VERIFY_TOKEN=EDITH2026

# ── SERVER ───────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
USER_LANGUAGE=English
USER_NAME=
